# Familiar Configuration
# Copy this file to .env and fill in the values

# Required — authentication token for gateway connections
# Generated automatically by setup.sh, or set your own
FAMILIAR_GATEWAY_TOKEN=

# Optional — Gemini API key for silver-tier routing
# Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional — Telegram bot for remote notifications
# Create a bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional — GitHub token for mining training data from your repos
# Create at https://github.com/settings/tokens (needs repo scope)
GITHUB_TOKEN=

# Optional — remote worker (Ubuntu GPU machine) for CUDA training
# Format: user@hostname (must have SSH key access)
WORKER_SSH=
# Format: http://hostname:18792
WORKER_URL=

# Optional — Mac SSH target (for syncing from worker back to Mac)
# Format: user@hostname
MAC_SSH=

# Optional — Claude Code proxy port (default: 18791)
CLAUDE_PROXY_PORT=18791

# Optional — max concurrent Claude sessions (default: 2)
CLAUDE_MAX_CONCURRENT=2
