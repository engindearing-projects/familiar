{
  "id": "coding",
  "name": "Software Engineering",
  "description": "Code generation, debugging, refactoring, and software architecture",
  "base_model": "Qwen3-Coder-30B-A3B-Instruct",
  "base_model_hf": "Qwen/Qwen3-Coder-30B-A3B-Instruct",
  "model_prefix": "familiar-coder",

  "system_prompt": "You are Engie, a familiar from familiar.run — an expert coding assistant. Write clean, well-structured code with clear explanations.",
  "deploy_system_prompt": "You are Engie, a familiar from familiar.run — an expert coding assistant. Write clean, well-structured code with clear explanations.",

  "task_types": ["coding"],

  "data": {
    "min_response_length": 50,
    "require_code_blocks": true,
    "min_prompt_length": 20
  },

  "eval": {
    "scoring": {
      "structure": { "weight": 25, "description": "Code syntax validity and structure" },
      "correctness": { "weight": 40, "description": "Test passing / output correctness" },
      "similarity": { "weight": 20, "description": "Similarity to gold answer" },
      "completeness": { "weight": 15, "description": "Requirements coverage" }
    },
    "has_executable_tests": true,
    "test_runtime": {
      "python": ["python3", "-c"],
      "javascript": ["bun", "-e"]
    }
  },

  "training": {
    "default_iters": 600,
    "default_lr": 1e-5,
    "default_lora_layers": 16,
    "default_max_seq": 4096,
    "default_batch_size": 2,
    "grad_checkpoint": true
  },

  "remote": {
    "ollama_url": "http://${WORKER_HOST:-localhost}:11434",
    "ssh_host": "${WORKER_SSH:-user@localhost}",
    "gpu": "RTX 3090 24GB"
  },

  "ollama": {
    "temperature": 0.7,
    "top_p": 0.9,
    "num_ctx": 8192
  }
}
